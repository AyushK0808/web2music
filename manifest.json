{
  "manifest_version": 3,
  "name": "Adaptive Audio",
  "version": "1.0",
  "description": "Generates ambient music based on webpage content",

  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "offscreen",
    "idle",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Adaptive Audio"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}